rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // emailKey must match JS: replace(/[@.]/g, "_")
    function emailKey(email) {
      return email.lower().replace("@", "_").replace(".", "_");
    }

    // Check if the requesting user has admin role
    function isAdmin() {
      let key = emailKey(request.auth.token.email);
      return exists(/databases/$(database)/documents/roles/$(key))
        && get(/databases/$(database)/documents/roles/$(key)).data.role == "admin";
    }

    // Evaluations collection
    match /evaluations/{ticketNumber} {
      allow read, create: if request.auth != null;
      allow update, delete: if request.auth != null
        && (resource.data.ownerUid == request.auth.uid || isAdmin());
    }

    // Roles collection — readable by all authenticated users, writable only by admins
    match /roles/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }

    // Audit log — readable and creatable by authenticated users
    match /auditLog/{logId} {
      allow read, create: if request.auth != null;
      allow update, delete: if false;
    }

    // Block everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
