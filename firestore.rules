rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // emailKey must match JS: replace(/[@.]/g, "_")
    function emailKey(email) {
      return email.lower().replace("[@.]", "_");
    }

    // Check if the requesting user has admin role
    function isAdmin() {
      let key = emailKey(request.auth.token.email);
      return exists(/databases/$(database)/documents/roles/$(key))
        && get(/databases/$(database)/documents/roles/$(key)).data.role == "admin";
    }

    // Evaluations collection
    match /evaluations/{ticketNumber} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if request.auth != null
        && (resource.data.ownerUid == request.auth.uid || isAdmin());
    }

    // Roles collection
    match /roles/{docId} {
      allow get:    if request.auth != null && (docId == emailKey(request.auth.token.email) || isAdmin());
      allow list:   if request.auth != null && isAdmin();
      allow write:  if request.auth != null && isAdmin();
      // Invitees may clear only their own mustSetPassword flag (nothing else)
      allow update: if request.auth != null
                    && docId == emailKey(request.auth.token.email)
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['mustSetPassword'])
                    && request.resource.data.mustSetPassword == false;
    }

    // Audit log — performedBy must match authenticated user's email
    match /auditLog/{logId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.performedBy == request.auth.token.email;
      allow update, delete: if false;
    }

    // Block everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
